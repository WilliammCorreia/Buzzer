{
	# Let's Encrypt registration address (certificate expiry notices).
	email {$ACME_EMAIL}

	# The admin API is unauthenticated; nothing in this stack uses it.
	admin off

	servers {
		# Caddy rewrites X-Forwarded-* from the connection it sees, unless the
		# peer is a trusted proxy — in which case it keeps the incoming ones.
		# Required when a host reverse proxy terminates TLS in front of Caddy,
		# otherwise X-Forwarded-Proto would be downgraded to "http" and Symfony
		# would emit http:// URLs and a session cookie without "secure".
		# Harmless when Caddy is exposed directly: public clients are never in
		# a private range, so their forged headers keep being overwritten.
		trusted_proxies static private_ranges
	}
}

# In production SITE_ADDRESS is the domain, and Caddy obtains and renews the
# TLS certificate on its own. Set it to ":80" to run without TLS (local check).
{$SITE_ADDRESS} {
	root * /app/public
	encode zstd gzip

	# AssetMapper emits digested, content-addressed filenames.
	header /assets/* Cache-Control "public, max-age=31536000, immutable"

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}

	php_fastcgi php:9000
	file_server

	log {
		output stdout
	}
}
