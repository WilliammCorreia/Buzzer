# Template for .env.prod.local — copy it on the server and fill in the secrets.
#   cp .env.prod.local.dist .env.prod.local
# .env.prod.local is gitignored: it must never be committed, and .dockerignore
# keeps it out of the image (secrets are injected as environment variables).

APP_ENV=prod
APP_DEBUG=0
# Generate a fresh one: php -r 'echo bin2hex(random_bytes(16)), PHP_EOL;'
APP_SECRET=REMPLACER_PAR_UN_SECRET_ALEATOIRE

# Must match DATABASE_URL below.
POSTGRES_DB=buzzer
POSTGRES_USER=buzzer
POSTGRES_PASSWORD=REMPLACER_PAR_UN_MOT_DE_PASSE_FORT
DATABASE_URL="postgresql://buzzer:REMPLACER_PAR_UN_MOT_DE_PASSE_FORT@database:5432/buzzer?serverVersion=16&charset=utf8"

# Mailpit is forbidden here. The sender domain must be verified in Resend.
MAILER_DSN=resend+api://re_VOTRE_CLE_API@default
MAILER_FROM="Buzzer <no-reply@willix.fr>"

# Absolute URLs generated outside of an HTTP request (CLI, messenger worker).
DEFAULT_URI=https://willix.fr

# TLS is terminated by a proxy, which forwards over the Docker network. Without
# this, Symfony would build http:// URLs and emit a session cookie without the
# "secure" attribute.
SYMFONY_TRUSTED_PROXIES=private_ranges
# x-forwarded-host and x-forwarded-port are deliberately NOT trusted: a client
# can forge them through a host reverse proxy, and Symfony would then build
# absolute URLs (e-mail confirmation links!) pointing at the attacker's domain.
SYMFONY_TRUSTED_HEADERS=x-forwarded-for,x-forwarded-proto
# Second line of defence against host header injection.
SYMFONY_TRUSTED_HOSTS=^willix\.fr$

MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=1

# Only needed by the app:nba:sync command.
SPORT_API=
