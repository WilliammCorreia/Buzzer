{% extends 'base.html.twig' %}
{% import '_ui.html.twig' as ui %}

{% block title %}Buzzer · {{ game.awayTeam.name }} @ {{ game.homeTeam.name }}{% endblock %}

{% block body %}
    <a href="{{ path('app_game_index') }}" class="mb-4 inline-flex items-center gap-1 text-sm font-semibold text-orange-600 hover:text-orange-500">
        ← Calendrier
    </a>

    {# --- En-tête du match ------------------------------------------------- #}
    <div class="card mb-6">
        <div class="mb-4 flex items-center justify-between gap-2">
            <span class="badge {{ game.status|status_class }}">{{ game.status.label }}</span>
            <span class="text-sm text-slate-500">
                {{ game.startsAt|date('d/m/Y · H:i') }}
                {% if game.season %} · {{ game.season.label }}{% endif %}
            </span>
        </div>

        <div class="grid grid-cols-[1fr_auto_1fr] items-center gap-3 sm:gap-6">
            {# Extérieur #}
            <div class="flex flex-col items-center gap-2 text-center">
                {{ ui.teamLogo(game.awayTeam, 'h-14 w-14 sm:h-20 sm:w-20') }}
                <span class="text-sm font-bold text-slate-900 sm:text-base">{{ game.awayTeam.name }}</span>
                <span class="text-[11px] uppercase tracking-wide text-slate-400">Extérieur</span>
            </div>

            {# Score / heure #}
            <div class="text-center">
                {% if game.homeScore is not null and game.awayScore is not null %}
                    <div class="text-3xl font-extrabold tabular-nums tracking-tight text-slate-900 sm:text-5xl">{{ game.awayScore }}<span class="mx-1 text-slate-300">–</span>{{ game.homeScore }}</div>
                    {% if game.winner %}
                        <div class="mt-1 text-xs font-semibold text-emerald-600">🏆 {{ game.winner.name }}</div>
                    {% endif %}
                {% else %}
                    <div class="text-2xl font-bold text-slate-300 sm:text-4xl">VS</div>
                {% endif %}
            </div>

            {# Domicile #}
            <div class="flex flex-col items-center gap-2 text-center">
                {{ ui.teamLogo(game.homeTeam, 'h-14 w-14 sm:h-20 sm:w-20') }}
                <span class="text-sm font-bold text-slate-900 sm:text-base">{{ game.homeTeam.name }}</span>
                <span class="text-[11px] uppercase tracking-wide text-slate-400">Domicile</span>
            </div>
        </div>

        <hr class="my-5 border-slate-200">

        {% if game.isOpenForPredictions %}
            <div class="flex flex-wrap items-center gap-3">
                <span class="badge bg-emerald-100 text-emerald-800 ring-emerald-200">Pronostics ouverts</span>
                {% if app.user %}
                    <a class="btn-primary" href="{{ path('app_prediction_new', {id: game.id}) }}">Pronostiquer</a>
                {% else %}
                    <a class="btn-primary" href="{{ path('app_login') }}">Connectez-vous pour pronostiquer</a>
                {% endif %}
            </div>
        {% else %}
            <span class="badge bg-slate-100 text-slate-700 ring-slate-200">Pronostics clôturés</span>
        {% endif %}

        {# --- Mes pronostics ------------------------------------------------ #}
        {% if userPredictions is not empty %}
            <hr class="my-5 border-slate-200">
            <h2 class="mb-3 text-sm font-bold uppercase tracking-wide text-slate-500">Vos pronostics</h2>
            <ul class="divide-y divide-slate-100">
                {% for prediction in userPredictions %}
                    <li class="flex flex-col gap-2 py-3 sm:flex-row sm:items-center sm:justify-between">
                        <div class="text-sm text-slate-700">
                            {% if prediction.type == 'match_winner' %}
                                <span class="font-semibold">Vainqueur :</span> {{ prediction.predictedWinner.name }}
                            {% elseif prediction.type == 'score' %}
                                <span class="font-semibold">Score :</span> {{ prediction.predictedAwayScore }} – {{ prediction.predictedHomeScore }}
                            {% elseif prediction.type == 'player_prop' %}
                                <span class="font-semibold">{{ prediction.player.fullName }}</span>
                                · {{ prediction.statType.label }} {{ prediction.comparison.label|lower }} {{ prediction.predictedValue }}
                            {% endif %}
                            <span class="badge {{ prediction.status|status_class }} ml-2">{{ prediction.status.label }}</span>
                        </div>
                        {% if is_granted('PREDICTION_DELETE', prediction) %}
                            <form method="post" action="{{ path('app_prediction_delete', {id: prediction.id}) }}"
                                  onsubmit="return confirm('Supprimer ce pronostic ?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete_prediction_' ~ prediction.id) }}">
                                <button class="btn-danger">Supprimer</button>
                            </form>
                        {% endif %}
                    </li>
                {% endfor %}
            </ul>
        {% endif %}
    </div>

    {# --- Commentaires ------------------------------------------------------ #}
    <section>
        <h2 class="mb-4 text-lg font-bold text-slate-900">
            Commentaires <span class="text-sm font-medium text-slate-400">({{ comments|length }})</span>
        </h2>

        {{ render(controller('App\\Controller\\CommentController::newForm', {'id': game.id})) }}

        {% if comments is empty %}
            <p class="text-sm text-slate-500">Aucun commentaire pour le moment.</p>
        {% else %}
            <ul class="space-y-3">
                {% for comment in comments %}
                    <li class="card !p-4">
                        <div class="mb-1 flex items-center justify-between gap-3">
                            <span class="flex items-center gap-2 text-sm font-semibold text-slate-900">
                                <span class="flex h-6 w-6 items-center justify-center rounded-full bg-slate-200 text-[10px] font-bold uppercase text-slate-600">{{ comment.author.username|first }}</span>
                                {{ comment.author.username }}
                            </span>
                            <span class="shrink-0 text-xs text-slate-400">{{ comment.createdAt|date('d/m/Y H:i') }}</span>
                        </div>
                        <p class="text-sm leading-relaxed text-slate-700">{{ comment.content }}</p>
                    </li>
                {% endfor %}
            </ul>
        {% endif %}
    </section>
{% endblock %}
