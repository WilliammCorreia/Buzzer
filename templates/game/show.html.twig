{% extends 'base.html.twig' %}

{% block title %}Buzzer · {{ game.awayTeam.name }} @ {{ game.homeTeam.name }}{% endblock %}

{% block body %}
    <a href="{{ path('app_game_index') }}" class="btn btn-sm btn-link px-0 mb-2">← Calendrier</a>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <span class="badge text-bg-{{ game.status|status_class }} mb-2">{{ game.status.label }}</span>
                    <h1 class="h4 mb-1">
                        {{ game.awayTeam.name }} <span class="text-secondary">@</span> {{ game.homeTeam.name }}
                    </h1>
                    <div class="text-secondary small">
                        {{ game.startsAt|date('l d F Y · H:i') }}
                        {% if game.season %} · {{ game.season.label }}{% endif %}
                    </div>
                </div>
                <div class="text-end">
                    {% if game.homeScore is not null and game.awayScore is not null %}
                        <div class="display-6 fw-bold">{{ game.awayScore }} – {{ game.homeScore }}</div>
                        {% if game.winner %}
                            <div class="small text-success">Vainqueur : {{ game.winner.name }}</div>
                        {% endif %}
                    {% else %}
                        <div class="display-6 fw-bold text-secondary">— : —</div>
                    {% endif %}
                </div>
            </div>

            <hr>

            {% if game.isOpenForPredictions %}
                <div class="d-flex align-items-center gap-2 flex-wrap">
                    <span class="badge text-bg-success">Pronostics ouverts</span>
                    {% if app.user %}
                        <a class="btn btn-primary btn-sm" href="{{ path('app_prediction_new', {id: game.id}) }}">Pronostiquer</a>
                    {% else %}
                        <a class="btn btn-primary btn-sm" href="{{ path('app_login') }}">Connectez-vous pour pronostiquer</a>
                    {% endif %}
                </div>
            {% else %}
                <span class="badge text-bg-secondary">Pronostics clôturés</span>
            {% endif %}

            {% if userPredictions is not empty %}
                <hr>
                <h2 class="h6">Vos pronostics</h2>
                <ul class="list-group">
                    {% for prediction in userPredictions %}
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <div>
                                {% if prediction.type == 'match_winner' %}
                                    <strong>Vainqueur&nbsp;:</strong> {{ prediction.predictedWinner.name }}
                                {% elseif prediction.type == 'score' %}
                                    <strong>Score&nbsp;:</strong> {{ prediction.predictedAwayScore }} – {{ prediction.predictedHomeScore }}
                                {% elseif prediction.type == 'player_prop' %}
                                    <strong>{{ prediction.player.fullName }}</strong>
                                    · {{ prediction.statType.label }} {{ prediction.comparison.label|lower }} {{ prediction.predictedValue }}
                                {% endif %}
                                <span class="badge text-bg-{{ prediction.status|status_class }} ms-2">{{ prediction.status.label }}</span>
                            </div>
                            {% if is_granted('PREDICTION_DELETE', prediction) %}
                                <form method="post" action="{{ path('app_prediction_delete', {id: prediction.id}) }}"
                                      onsubmit="return confirm('Supprimer ce pronostic ?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete_prediction_' ~ prediction.id) }}">
                                    <button class="btn btn-sm btn-outline-danger">Supprimer</button>
                                </form>
                            {% endif %}
                        </li>
                    {% endfor %}
                </ul>
            {% endif %}
        </div>
    </div>

    <h2 class="h5 mb-3">Commentaires <span class="text-secondary">({{ comments|length }})</span></h2>
    {{ render(controller('App\\Controller\\CommentController::newForm', {'id': game.id})) }}
    {% if comments is empty %}
        <p class="text-secondary">Aucun commentaire pour le moment.</p>
    {% else %}
        <ul class="list-group">
            {% for comment in comments %}
                <li class="list-group-item">
                    <div class="d-flex justify-content-between">
                        <span class="fw-semibold">{{ comment.author.username }}</span>
                        <span class="text-secondary small">{{ comment.createdAt|date('d/m/Y H:i') }}</span>
                    </div>
                    <div>{{ comment.content }}</div>
                </li>
            {% endfor %}
        </ul>
    {% endif %}
{% endblock %}
