{% extends 'base.html.twig' %}

{% block title %}Buzzer · Calendrier{% endblock %}

{% block body %}
    <div class="mb-5 flex items-center justify-between">
        <h1 class="text-xl font-bold text-slate-900">Calendrier des matchs</h1>
        <span class="text-sm text-slate-500">{{ total }} match{{ total > 1 ? 's' : '' }}</span>
    </div>

    {% if total == 0 %}
        <div class="card text-sm text-slate-500">
            Aucun match en base. Chargez les fixtures ou lancez la synchronisation NBA.
        </div>
    {% else %}
        <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
            {% for game in games %}
                <article class="card flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
                    <div class="min-w-0">
                        <div class="flex items-center gap-2 text-sm font-semibold text-slate-900">
                            <span class="truncate">{{ game.awayTeam.name }}</span>
                            <span class="shrink-0 text-xs font-bold uppercase text-slate-400">@</span>
                            <span class="truncate">{{ game.homeTeam.name }}</span>
                        </div>
                        <div class="mt-2 flex flex-wrap items-center gap-2 text-xs text-slate-500">
                            <span>{{ game.startsAt|date('d/m/Y H:i') }}</span>
                            <span class="badge {{ game.status|status_class }}">{{ game.status.label }}</span>
                            {% if game.homeScore is not null and game.awayScore is not null %}
                                <span class="font-bold text-slate-900">{{ game.awayScore }} – {{ game.homeScore }}</span>
                            {% endif %}
                        </div>
                    </div>
                    <a class="btn-secondary shrink-0 self-start sm:self-center" href="{{ path('app_game_show', {id: game.id}) }}">
                        Détails
                    </a>
                </article>
            {% endfor %}
        </div>

        {% if pages > 1 %}
            <nav aria-label="Pagination" class="mt-6 flex items-center justify-center gap-3">
                {% if page > 1 %}
                    <a class="btn-secondary" href="{{ path('app_game_index', {page: page - 1}) }}">← Précédent</a>
                {% endif %}
                <span class="text-sm font-medium text-slate-500">Page {{ page }} / {{ pages }}</span>
                {% if page < pages %}
                    <a class="btn-secondary" href="{{ path('app_game_index', {page: page + 1}) }}">Suivant →</a>
                {% endif %}
            </nav>
        {% endif %}
    {% endif %}
{% endblock %}
