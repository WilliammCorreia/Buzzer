{% extends 'base.html.twig' %}

{% block title %}Buzzer · Connexion{% endblock %}

{% block body %}
    <div class="mx-auto max-w-md">
        <div class="card">
            <h1 class="mb-6 text-center text-xl font-bold text-slate-900">Connexion</h1>

            <form method="post">
                {% if error %}
                    <div class="mb-4 rounded-xl border border-red-200 bg-red-50 p-4 text-sm font-medium text-red-800" role="alert">
                        {{ error.messageKey|trans(error.messageData, 'security') }}
                    </div>
                {% endif %}

                {% if app.user %}
                    <div class="mb-4 rounded-xl border border-slate-200 bg-slate-50 p-4 text-sm text-slate-600">
                        Vous êtes connecté en tant que {{ app.user.userIdentifier }},
                        <a class="font-semibold text-orange-600 hover:text-orange-500" href="{{ path('app_logout') }}">se déconnecter</a>.
                    </div>
                {% endif %}

                <div class="mb-5">
                    <label for="inputEmail" class="mb-1.5 block text-sm font-medium text-slate-700">Adresse e-mail</label>
                    <input type="email" value="{{ last_username }}" name="email" id="inputEmail"
                           class="block w-full rounded-lg border-0 bg-white px-3 py-2.5 text-sm text-slate-900 shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-orange-600"
                           autocomplete="email" required autofocus>
                </div>

                <div class="mb-5">
                    <label for="inputPassword" class="mb-1.5 block text-sm font-medium text-slate-700">Mot de passe</label>
                    <input type="password" name="password" id="inputPassword"
                           class="block w-full rounded-lg border-0 bg-white px-3 py-2.5 text-sm text-slate-900 shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-orange-600"
                           autocomplete="current-password" required>
                </div>

                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                <label class="mb-5 inline-flex cursor-pointer items-center gap-2 text-sm text-slate-700">
                    <input class="h-4 w-4 rounded border-slate-300 text-orange-600 focus:ring-orange-600"
                           type="checkbox" name="_remember_me" checked>
                    Se souvenir de moi
                </label>

                <button class="btn-primary w-full" type="submit">Se connecter</button>
            </form>
        </div>
        <p class="mt-4 text-center text-sm text-slate-500">
            Pas encore de compte ?
            <a class="font-semibold text-orange-600 hover:text-orange-500" href="{{ path('app_register') }}">S'inscrire</a>
        </p>
    </div>
{% endblock %}
