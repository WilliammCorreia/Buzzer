{% extends 'base.html.twig' %}

{% block title %}Buzzer · Mon historique{% endblock %}

{% block body %}
    <h1 class="h3 mb-4">Mon historique</h1>

    {# --- Statistiques --------------------------------------------------- #}
    <div class="row row-cols-2 row-cols-md-5 g-3 mb-4">
        {% set cards = [
            {label: 'Pronostics', value: stats.total, cls: 'secondary'},
            {label: 'En attente', value: stats.pending, cls: 'warning'},
            {label: 'Gagnés', value: stats.won, cls: 'success'},
            {label: 'Perdus', value: stats.lost, cls: 'danger'},
            {label: 'Points', value: stats.points, cls: 'primary'},
        ] %}
        {% for card in cards %}
            <div class="col">
                <div class="card text-center shadow-sm h-100">
                    <div class="card-body py-3">
                        <div class="display-6 fw-bold text-{{ card.cls }}">{{ card.value }}</div>
                        <div class="text-secondary small text-uppercase">{{ card.label }}</div>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>

    <p class="mb-4">
        Taux de réussite :
        {% if stats.successRate is not null %}
            <span class="badge text-bg-{{ stats.successRate >= 50 ? 'success' : 'danger' }} fs-6">{{ stats.successRate }}&nbsp;%</span>
            <span class="text-secondary small">(sur {{ stats.won + stats.lost }} pronostic(s) réglé(s))</span>
        {% else %}
            <span class="text-secondary">aucun pronostic encore réglé</span>
        {% endif %}
    </p>

    {# --- Badges --------------------------------------------------------- #}
    {% if app.user.userBadges is not empty %}
        <h2 class="h5 mb-2">Mes badges</h2>
        <div class="mb-4">
            {% for userBadge in app.user.userBadges %}
                <span class="badge text-bg-warning me-1 mb-1 p-2" title="{{ userBadge.badge.description }}">
                    🏅 {{ userBadge.badge.name }}
                </span>
            {% endfor %}
        </div>
    {% endif %}

    {# --- Liste des pronostics ------------------------------------------- #}
    {% if history is empty %}
        <div class="alert alert-info">
            Vous n'avez pas encore de pronostic. <a href="{{ path('app_game_index') }}">Voir le calendrier</a>.
        </div>
    {% else %}
        <div class="table-responsive">
            <table class="table table-hover align-middle bg-body shadow-sm rounded">
                <thead>
                    <tr>
                        <th>Match</th>
                        <th>Mon pronostic</th>
                        <th class="text-center">Statut</th>
                        <th class="text-end">Points</th>
                    </tr>
                </thead>
                <tbody>
                    {% for prediction in history %}
                        <tr>
                            <td>
                                <a href="{{ path('app_game_show', {id: prediction.game.id}) }}" class="text-decoration-none">
                                    {{ prediction.game.awayTeam.name }} @ {{ prediction.game.homeTeam.name }}
                                </a>
                                <div class="text-secondary small">{{ prediction.game.startsAt|date('d/m/Y') }}</div>
                            </td>
                            <td>
                                {% if prediction.type == 'match_winner' %}
                                    Vainqueur : <strong>{{ prediction.predictedWinner.name }}</strong>
                                {% elseif prediction.type == 'score' %}
                                    Score : <strong>{{ prediction.predictedAwayScore }} – {{ prediction.predictedHomeScore }}</strong>
                                {% elseif prediction.type == 'player_prop' %}
                                    <strong>{{ prediction.player.fullName }}</strong>
                                    · {{ prediction.statType.label }} {{ prediction.comparison.label|lower }} {{ prediction.predictedValue }}
                                {% endif %}
                            </td>
                            <td class="text-center">
                                <span class="badge text-bg-{{ prediction.status|status_class }}">{{ prediction.status.label }}</span>
                            </td>
                            <td class="text-end fw-semibold">
                                {{ prediction.pointsAwarded > 0 ? '+' ~ prediction.pointsAwarded : '—' }}
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}
{% endblock %}
