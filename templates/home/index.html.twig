{% extends 'base.html.twig' %}
{% import '_ui.html.twig' as ui %}

{% block title %}Buzzer · Accueil{% endblock %}

{% block body %}
    {# --- Hero ------------------------------------------------------------ #}
    <section class="relative overflow-hidden rounded-3xl bg-slate-900 px-6 py-10 sm:px-10 sm:py-14">
        <div class="absolute -right-10 -top-10 text-[10rem] opacity-10 sm:text-[14rem]" aria-hidden="true">🏀</div>
        <div class="relative max-w-2xl">
            <h1 class="text-3xl font-extrabold tracking-tight text-white sm:text-4xl">
                Buzzer<span class="text-orange-500">.</span>
            </h1>
            <p class="mt-3 text-base leading-relaxed text-slate-300 sm:text-lg">
                Pronostiquez les matchs NBA, défiez vos amis au sein de ligues privées
                et grimpez dans les classements. Sans argent réel — juste pour la gloire.
            </p>
            <div class="mt-6 flex flex-col gap-3 sm:flex-row">
                {% if not app.user %}
                    <a class="btn-primary" href="{{ path('app_register') }}">Créer un compte</a>
                    <a class="btn-secondary" href="{{ path('app_login') }}">Se connecter</a>
                {% else %}
                    <a class="btn-primary" href="{{ path('app_game_index') }}">Voir le calendrier</a>
                    <a class="btn-secondary" href="{{ path('app_prediction_history') }}">Mon historique</a>
                {% endif %}
            </div>
        </div>
    </section>

    {# --- Prochains matchs -------------------------------------------------- #}
    <section class="mt-8">
        <div class="mb-4 flex items-center justify-between">
            <h2 class="text-lg font-bold text-slate-900">Prochains matchs</h2>
            <a href="{{ path('app_game_index') }}" class="text-sm font-semibold text-orange-600 hover:text-orange-500">
                Tout le calendrier →
            </a>
        </div>

        {% if upcomingGames is empty %}
            <div class="card text-sm text-slate-500">
                Aucun match programmé pour le moment. Lancez la synchronisation NBA ou chargez les fixtures.
            </div>
        {% else %}
            <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
                {% for game in upcomingGames %}
                    <a href="{{ path('app_game_show', {id: game.id}) }}"
                       class="card group transition hover:-translate-y-0.5 hover:border-orange-300 hover:shadow-md">
                        <div class="flex items-center justify-between gap-2">
                            {{ ui.team(game.awayTeam) }}
                            <span class="shrink-0 text-xs font-bold uppercase text-slate-400">@</span>
                            {{ ui.team(game.homeTeam, 'end') }}
                        </div>
                        <div class="mt-3 flex items-center justify-between">
                            <span class="text-xs text-slate-500">{{ game.startsAt|date('d/m/Y H:i') }}</span>
                            <span class="badge {{ game.status|status_class }}">{{ game.status.label }}</span>
                        </div>
                    </a>
                {% endfor %}
            </div>
        {% endif %}
    </section>
{% endblock %}
