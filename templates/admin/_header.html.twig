{% set tab = tab|default('dashboard') %}
<div class="mb-6">
    <div class="flex items-center gap-3">
        <span class="flex h-11 w-11 items-center justify-center rounded-xl bg-slate-900 text-xl" aria-hidden="true">🛠️</span>
        <div>
            <h1 class="text-xl font-bold text-slate-900">Administration</h1>
            <p class="text-sm text-slate-500">Supervision de la plateforme</p>
        </div>
    </div>

    <nav class="mt-4 flex flex-wrap gap-4 border-b border-slate-200 text-sm font-medium">
        {% set base = '-mb-px border-b-2 px-1 pb-3 transition' %}
        {% set on = 'border-orange-600 text-slate-900' %}
        {% set off = 'border-transparent text-slate-500 hover:border-slate-300 hover:text-slate-700' %}
        <a href="{{ path('app_admin_dashboard') }}" class="{{ base }} {{ tab == 'dashboard' ? on : off }}">Tableau de bord</a>
        <a href="{{ path('app_admin_users') }}" class="{{ base }} {{ tab == 'users' ? on : off }}">Utilisateurs</a>
        <a href="{{ path('app_moderation_index') }}" class="{{ base }} {{ off }}">Modération</a>
    </nav>
</div>
