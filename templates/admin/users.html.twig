{% extends 'base.html.twig' %}

{% block title %}Buzzer · Administration · Utilisateurs{% endblock %}

{% block body %}
    {{ include('admin/_header.html.twig', {tab: 'users'}) }}

    <div class="mb-4 flex items-center justify-between">
        <h2 class="text-sm font-bold uppercase tracking-wide text-slate-500">{{ users|length }} utilisateur(s)</h2>
    </div>

    <div class="space-y-3">
        {% for user in users %}
            <div class="card !p-4">
                <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                    <div class="flex items-center gap-3">
                        <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-orange-600 text-sm font-bold uppercase text-white">{{ user.username|first }}</span>
                        <div class="min-w-0">
                            <div class="truncate text-sm font-semibold text-slate-900">{{ user.username }}</div>
                            <div class="truncate text-xs text-slate-500">{{ user.email }}</div>
                        </div>
                    </div>

                    <div class="flex flex-wrap items-center gap-2">
                        {% for role in user.roles %}
                            {% set role_class = {
                                'ROLE_ADMIN': 'bg-red-100 text-red-700 ring-red-200',
                                'ROLE_MANAGER': 'bg-amber-100 text-amber-800 ring-amber-200',
                            }[role]|default('bg-slate-100 text-slate-600 ring-slate-200') %}
                            <span class="badge {{ role_class }}">{{ role|replace({'ROLE_': ''}) }}</span>
                        {% endfor %}

                        {% if user.verified %}
                            <span class="badge bg-emerald-100 text-emerald-800 ring-emerald-200">✓ vérifié</span>
                        {% else %}
                            <span class="badge bg-amber-100 text-amber-800 ring-amber-200">non vérifié</span>
                        {% endif %}

                        {% if user.userBadges|length > 0 %}
                            <span class="badge bg-slate-100 text-slate-600 ring-slate-200">🏅 {{ user.userBadges|length }}</span>
                        {% endif %}

                        <span class="text-xs text-slate-400">Inscrit le {{ user.createdAt|date('d/m/Y') }}</span>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>
{% endblock %}
