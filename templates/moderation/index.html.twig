{% extends 'base.html.twig' %}

{% block title %}Buzzer · Modération{% endblock %}

{% block body %}
    <h1 class="mb-5 text-xl font-bold text-slate-900">Modération des commentaires</h1>

    {% if comments is empty %}
        <div class="card text-sm text-slate-500">Aucun commentaire pour l'instant.</div>
    {% else %}
        <ul class="space-y-3">
            {% for comment in comments %}
                <li class="card !p-4 {{ comment.hidden ? 'opacity-70' }}">
                    <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
                        <div class="min-w-0">
                            <div class="flex flex-wrap items-center gap-2 text-sm">
                                <span class="font-semibold text-slate-900">{{ comment.author.username }}</span>
                                <span class="text-xs text-slate-400">sur</span>
                                <span class="text-xs font-medium text-slate-600">{{ comment.game.awayTeam.name }} @ {{ comment.game.homeTeam.name }}</span>
                                <span class="text-xs text-slate-400">· {{ comment.createdAt|date('d/m/Y H:i') }}</span>
                                {% if comment.hidden %}
                                    <span class="badge bg-slate-100 text-slate-700 ring-slate-200">Masqué</span>
                                {% else %}
                                    <span class="badge bg-emerald-100 text-emerald-800 ring-emerald-200">Visible</span>
                                {% endif %}
                            </div>
                            <p class="mt-2 text-sm leading-relaxed text-slate-700">
                                {{ comment.content|length > 160 ? comment.content|slice(0, 160) ~ '…' : comment.content }}
                            </p>
                        </div>
                        <form method="post" action="{{ path('app_moderation_comment_toggle', {id: comment.id}) }}" class="shrink-0">
                            <input type="hidden" name="_token" value="{{ csrf_token('moderate_comment_' ~ comment.id) }}">
                            <button class="{{ comment.hidden ? 'btn-secondary !px-3 !py-1.5 !text-xs' : 'btn-danger' }}">
                                {{ comment.hidden ? 'Réafficher' : 'Masquer' }}
                            </button>
                        </form>
                    </div>
                </li>
            {% endfor %}
        </ul>
    {% endif %}
{% endblock %}
