<!DOCTYPE html>
<html lang="fr" class="h-full">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}Buzzer · Pronostics NBA{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.1em%22 font-size=%2296%22>🏀</text></svg>">

        {% block stylesheets %}{% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body class="flex min-h-full flex-col bg-slate-50 text-slate-900 antialiased">
        {% block navbar %}
            <header class="sticky top-0 z-40 bg-slate-900 shadow-md">
                <nav class="mx-auto flex h-16 max-w-6xl items-center justify-between px-4 sm:px-6" aria-label="Navigation principale">
                    <div class="flex items-center gap-6">
                        <a href="{{ path('app_home') }}" class="flex items-center gap-2 text-lg font-bold tracking-tight text-white">
                            <span aria-hidden="true">🏀</span> Buzzer
                        </a>
                        <div class="hidden items-center gap-1 md:flex">
                            <a class="nav-link" href="{{ path('app_game_index') }}">Calendrier</a>
                            {% if app.user %}
                                <a class="nav-link" href="{{ path('app_league_index') }}">Mes ligues</a>
                                <a class="nav-link" href="{{ path('app_prediction_history') }}">Mon historique</a>
                            {% endif %}
                            {% if is_granted('ROLE_MANAGER') %}
                                <a class="nav-link text-amber-300 hover:text-amber-200" href="{{ path('app_moderation_index') }}">Modération</a>
                            {% endif %}
                            {% if is_granted('ROLE_ADMIN') %}
                                <a class="nav-link text-red-300 hover:text-red-200" href="#">Administration</a>
                            {% endif %}
                        </div>
                    </div>

                    <div class="hidden items-center gap-3 md:flex">
                        {% if app.user %}
                            <a href="{{ path('app_profile_show') }}" class="flex items-center gap-2 rounded-lg px-3 py-2 text-sm font-medium text-slate-200 transition hover:bg-slate-800">
                                <span class="flex h-7 w-7 items-center justify-center rounded-full bg-orange-600 text-xs font-bold uppercase text-white">{{ app.user.username|first }}</span>
                                {{ app.user.username }}
                            </a>
                            <a class="btn-secondary !py-2" href="{{ path('app_logout') }}">Déconnexion</a>
                        {% else %}
                            <a class="nav-link" href="{{ path('app_register') }}">Inscription</a>
                            <a class="btn-primary !py-2" href="{{ path('app_login') }}">Connexion</a>
                        {% endif %}
                    </div>

                    <button id="nav-toggle" type="button" aria-expanded="false" aria-controls="mobile-menu"
                            class="inline-flex items-center justify-center rounded-lg p-2 text-slate-300 transition hover:bg-slate-800 hover:text-white md:hidden">
                        <span class="sr-only">Ouvrir le menu</span>
                        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"/>
                        </svg>
                    </button>
                </nav>

                <div id="mobile-menu" class="hidden border-t border-slate-800 px-4 pb-4 pt-2 md:hidden">
                    <div class="flex flex-col gap-1">
                        <a class="nav-link-mobile" href="{{ path('app_game_index') }}">Calendrier</a>
                        {% if app.user %}
                            <a class="nav-link-mobile" href="{{ path('app_league_index') }}">Mes ligues</a>
                            <a class="nav-link-mobile" href="{{ path('app_prediction_history') }}">Mon historique</a>
                            <a class="nav-link-mobile" href="{{ path('app_profile_show') }}">Mon profil</a>
                        {% endif %}
                        {% if is_granted('ROLE_MANAGER') %}
                            <a class="nav-link-mobile text-amber-300" href="{{ path('app_moderation_index') }}">Modération</a>
                        {% endif %}
                        {% if is_granted('ROLE_ADMIN') %}
                            <a class="nav-link-mobile text-red-300" href="#">Administration</a>
                        {% endif %}
                    </div>
                    <div class="mt-3 flex flex-col gap-2 border-t border-slate-800 pt-3">
                        {% if app.user %}
                            <div class="px-3 text-sm text-slate-400">Connecté : <span class="font-semibold text-slate-200">{{ app.user.username }}</span></div>
                            <a class="btn-secondary" href="{{ path('app_logout') }}">Déconnexion</a>
                        {% else %}
                            <a class="btn-primary" href="{{ path('app_login') }}">Connexion</a>
                            <a class="btn-secondary" href="{{ path('app_register') }}">Inscription</a>
                        {% endif %}
                    </div>
                </div>
            </header>
        {% endblock %}

        <main class="mx-auto w-full max-w-6xl grow px-4 py-6 sm:px-6 sm:py-8">
            {% block flashes %}
                {% for label, messages in app.flashes %}
                    {% for message in messages %}
                        <div class="mb-4 flex items-start gap-3 rounded-xl border p-4 text-sm font-medium
                                    {{ label == 'error' ? 'border-red-200 bg-red-50 text-red-800' : 'border-emerald-200 bg-emerald-50 text-emerald-800' }}"
                             role="alert">
                            <span aria-hidden="true">{{ label == 'error' ? '⚠️' : '✅' }}</span>
                            <span>{{ message }}</span>
                        </div>
                    {% endfor %}
                {% endfor %}
            {% endblock %}

            {% block body %}{% endblock %}
        </main>

        {% block footer %}
            <footer class="border-t border-slate-200 bg-white">
                <div class="mx-auto flex max-w-6xl flex-col gap-1 px-4 py-5 text-xs text-slate-500 sm:flex-row sm:items-center sm:justify-between sm:px-6">
                    <span>🏀 Buzzer — pronostics NBA · projet pédagogique Symfony</span>
                    <span>{{ "now"|date("Y") }}</span>
                </div>
            </footer>
        {% endblock %}
    </body>
</html>
