{% extends 'base.html.twig' %}

{% block title %}Buzzer · Rejoindre une ligue{% endblock %}

{% block body %}
    <div class="mx-auto max-w-md">
        <div class="card">
            <h1 class="mb-2 text-xl font-bold text-slate-900">Rejoindre une ligue</h1>
            <p class="mb-6 text-sm text-slate-500">Saisissez le code d'invitation transmis par le propriétaire de la ligue.</p>

            {{ form_start(form) }}
                {{ form_row(form.inviteCode) }}
                <button class="btn-primary w-full" type="submit">Rejoindre</button>
            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}
