{% extends 'base.html.twig' %}

{% block title %}Buzzer · Créer une ligue{% endblock %}

{% block body %}
    <div class="mx-auto max-w-md">
        <div class="card">
            <h1 class="mb-2 text-xl font-bold text-slate-900">Créer une ligue</h1>
            <p class="mb-6 text-sm text-slate-500">Un code d'invitation unique sera généré pour inviter vos amis.</p>

            {{ form_start(form) }}
                {{ form_row(form.name) }}
                {{ form_row(form.isPrivate) }}
                <button class="btn-primary w-full" type="submit">Créer</button>
            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}
