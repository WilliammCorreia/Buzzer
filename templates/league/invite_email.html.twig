{% extends 'email/base_email.html.twig' %}

{% import 'email/_macros.html.twig' as email %}

{% block preheader %}Rejoignez la ligue « {{ league.name }} » et affrontez ses membres en pronostics NBA.{% endblock %}

{% block content %}
    <h1 style="margin:0 0 16px;font-size:22px;line-height:1.3;font-weight:700;color:#0f172a;">
        Vous êtes invité(e) à rejoindre une ligue&nbsp;!
    </h1>

    <p style="margin:0 0 8px;">
        {% if inviter is defined and inviter %}<strong>{{ inviter.username }}</strong> vous invite{% else %}Vous avez été invité(e){% endif %}
        à rejoindre la ligue <strong>« {{ league.name }} »</strong> sur Buzzer,
        pour affronter ses membres en pronostics NBA.
    </p>

    {{ email.button(url('app_league_join', {code: league.inviteCode}), 'Rejoindre la ligue') }}

    <p style="margin:0 0 12px;font-size:13px;color:#64748b;">
        Vous pouvez aussi saisir ce code d'invitation une fois connecté(e) :
    </p>

    <table role="presentation" cellpadding="0" cellspacing="0" style="margin:0 auto;">
        <tr>
            <td style="background-color:#f8fafc;border:1px dashed #cbd5e1;border-radius:8px;padding:12px 24px;font-family:'SFMono-Regular',Consolas,'Liberation Mono',Menlo,monospace;font-size:18px;font-weight:700;letter-spacing:3px;color:#0f172a;">
                {{ league.inviteCode }}
            </td>
        </tr>
    </table>

    {{ email.fallback_link(url('app_league_join', {code: league.inviteCode})) }}
{% endblock %}
